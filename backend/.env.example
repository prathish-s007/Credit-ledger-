# ─── Server Configuration ──────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ─── MongoDB Configuration ─────────────────────────────────────────────────────
# LOCAL DEVELOPMENT — MongoDB Compass manages this database
MONGO_URI=mongodb://localhost:27017/digital_credit_ledger

# PRODUCTION — MongoDB Atlas (uncomment and fill in for production)
# MONGO_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority

# ─── JWT Configuration ─────────────────────────────────────────────────────────
# Generate a secure secret: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=REPLACE_WITH_A_LONG_RANDOM_SECRET_STRING
JWT_EXPIRES_IN=7d

# ─── CORS — Frontend URL ───────────────────────────────────────────────────────
# Development
CLIENT_URL=http://localhost:5173
# Production (Vercel URL)
# CLIENT_URL=https://your-app.vercel.app

# ─── Rate Limiting ─────────────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=20
